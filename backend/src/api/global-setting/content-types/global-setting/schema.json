{
  "kind": "singleType",
  "collectionName": "global_settings",
  "info": {
    "singularName": "global-setting",
    "pluralName": "global-settings",
    "displayName": "Global Settings"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "short_name": {
      "type": "string",
      "default": "HPJ",
      "required": true
    },
    "full_name": {
      "type": "string",
      "default": "HPJ Holdings LLC",
      "required": true
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "default_footer_logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "instagram_url": {
      "type": "string"
    },
    "youtube_url": {
      "type": "string"
    },
    "facebook_url": {
      "type": "string"
    },
    "tagline": {
      "type": "text",
      "default": "We lead with experience, driven by professionalism, and guided by a commitment to lasting success."
    },
    "emails": {
      "type": "component",
      "component": "contacts.email",
      "repeatable": true,
      "required": true
    },
    "phone_numbers": {
      "type": "component",
      "component": "contacts.phone",
      "repeatable": true
    },
    "address": {
      "type": "text"
    },
    "address_map_url": {
      "type": "string"
    }
  }
}
