---
import FooterSocialLink from "@components/ui/links/FooterSocialLink.astro";
import enStrings from "@utils/navigation.ts";
import Icon from "@components/ui/icons/Icon.astro";
import BrandLogoFooter from "@/components/BrandLogoFooter.astro";
import type { StrapiImageType, GlobalSettings } from "@/types/common";

const { customFooterImage, globalSettings } = Astro.props;

interface Props {
  customFooterImage?: StrapiImageType | null;
  globalSettings?: GlobalSettings | null;
}

const footerBottomLinks = enStrings.getFooterBottomLinks(globalSettings?.policy_titles);
const contactColLabel = globalSettings?.footer_col_contact_label || "Contact Us";
const copyrightText = globalSettings?.copyright_text || "Copyright © 2026 HPJ Holdings LLC";
const footerLinks = enStrings.getFooterLinks(
  globalSettings?.navigation_titles,
  globalSettings?.footer_col_pages_label,
  globalSettings?.footer_col_organisations_label,
);

---

<footer class=" w-full bg-[#F7F7F7] dark:bg-neutral-900">
  <div class="mx-auto w-full max-w-340 px-4 pt-20 pb-[30px] sm:px-6 sm:py-10 lg:px-10 lg:pt-20">
    <div class="grid grid-cols-2 gap-[30px] md:grid-cols-4 md:lg:grid-cols-4 xl:grid-cols-[355px_1fr_1fr_285px]">
      <div class="col-span-full flex flex-col items-center sm:block md:w-fit lg:col-span-1 xl:w-[355px]">
        
        <BrandLogoFooter className="order-1 object-cover mix-blend-exclusion" customFooterImage={customFooterImage ?? globalSettings?.default_footer_logo} />

        {(globalSettings?.instagram_url || globalSettings?.youtube_url || globalSettings?.facebook_url) && (
          <div
            class="text-gray-90 order-2 mt-[34px] flex justify-center gap-x-5 gap-y-2 sm:flex sm:items-center sm:justify-start sm:gap-y-0 md:order-1 md:mt-[30px] md:gap-5"
          >
            {globalSettings?.instagram_url && <FooterSocialLink url={globalSettings.instagram_url}><Icon name="instagram" /></FooterSocialLink>}
            {globalSettings?.youtube_url && <FooterSocialLink url={globalSettings.youtube_url}><Icon name="youtube" /></FooterSocialLink>}
            {globalSettings?.facebook_url && <FooterSocialLink url={globalSettings.facebook_url}><Icon name="facebook" /></FooterSocialLink>}
          </div>
        )}

        {globalSettings?.tagline && (
          <p class="text-text-main order-1 mt-[30px] text-center font-bold sm:max-w-[343px] sm:text-start">
            {globalSettings.tagline}
          </p>
        )}
      </div>
      {
        footerLinks.map((section) => (
          <div class="col-span-1">
            <h3 class="text-text-main font-bold dark:text-neutral-200">{section.section}</h3>
            <ul class="mt-4 grid space-y-3 md:mt-10">
              {section.links.map((link) => (
                <li class="mb-[13px] md:mb-4">
                  <a
                    href={link.url}
                    class="inline-flex gap-x-2 rounded-lg text-[15px] text-[#5B5F68] ring-zinc-500 outline-hidden transition duration-300 hover:text-neutral-500 focus-visible:ring-3 md:text-base dark:text-neutral-400 dark:ring-zinc-200 dark:hover:text-neutral-300 dark:focus:outline-hidden"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <div class="col-span-2 lg:col-span-1">
        <h3 class="text-text-main font-bold">
          {contactColLabel}
        </h3>

        <ul class="text-text-secondary mt-4 flex flex-col gap-4 text-[15px] md:mt-10 md:text-base">
          {globalSettings?.emails?.map(({ email }) => (
            <li class="flex items-center gap-2.5">
              <Icon name="email" className="text-gray-90 min-w-5" />
              <a href={`mailto:${email}`}>{email}</a>
            </li>
          ))}
          {globalSettings?.phone_numbers?.map(({ phone_number }) => phone_number && (
            <li class="flex items-center gap-2.5">
              <Icon name="phone" className="text-gray-90 mb-0.5 min-w-5" />
              <a href={`tel:${phone_number}`}>{phone_number}</a>
            </li>
          ))}
          {globalSettings?.address && (
            <li class="flex items-start gap-2.5">
              <Icon name="locationMarker" className="text-gray-90 mt-0.5 min-w-5" />
              <p>{globalSettings.address}</p>
            </li>
          )}
        </ul>
      </div>
    </div>
  </div>

  <div class="w-full">
    <div
      class="mx-auto flex w-full max-w-340 grid-cols-1 flex-col gap-3 px-4 py-4 pt-0 pb-10 text-[#5B5F68] sm:px-6 md:flex md:flex-row md:justify-between md:gap-6 md:py-10 lg:px-10"
    >
      <div class="order-1 mb-1 border-t-[0.5px] border-t-[#999999] md:hidden"></div>
      <div class="order-1 flex md:w-fit items-center justify-between">
        <p class="text-xs md:text-sm lg:text-base">
          {copyrightText}
        </p>
      </div>

      <ul
        class="order-2 row-start-2 flex flex-wrap justify-between gap-x-6 gap-y-2 text-xs sm:justify-start lg:self-end lg:text-base"
      >
        {
          footerBottomLinks.map((link) => {
            if (link.url !== "/cookie-policy") {
              return (
                <li>
                  <a class="w-fit text-nowrap" href={link.url}>
                    {link.name}
                  </a>
                </li>
              );
            }
            return (
              <li class="hidden sm:block">
                <a class="w-0 text-nowrap sm:w-fit" href={link.url}>
                  {link.name}
                </a>
              </li>
            );
          })
        }
      </ul>

      <script>
        const year = new Date().getFullYear();
        const element = document.getElementById("current-year");
        element!.innerText = year.toString();
      </script>
    </div>
  </div>
</footer>
